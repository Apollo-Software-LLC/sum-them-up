{
    "manifest_version": 3,
    "name": "Sum Them Up!",
    "description": "A simple extension that allows to sum numbers of the same kind on a webpage.",
    "version": "1.0.0",
    "author": "APOLLO SOFTWARE LLC",
    "icons": {
        "32": "plus32.png",
        "128": "plus128.png"
    },
    "permissions": ["contextMenus"],
    "background": { 
        "service_worker": "background.js"
    },
    "content_scripts": [{
        "js": ["foreground.js"],
        "matches": ["<all_urls>"]
    }],
    "action": {
        "default_popup": "popup.html"
    }
}